# Port the server listens on (default 8787).
PORT=8787
# SQLite database file. Defaults: in production (NODE_ENV=production)
# ~/.config/iread/iread.db (honors $XDG_CONFIG_HOME); in dev, repo-local
# data/iread.db so development never touches real data.
DB_PATH=data/iread.db
# OPML mirror file. The current subscription set is auto-saved here as OPML 2.0
# on every change (add/delete/import/refresh) and at startup, so it is always
# ready to share or back up. Defaults to feeds.opml next to the database. Set to
# an empty value to disable the on-disk mirror.
OPML_PATH=data/feeds.opml
